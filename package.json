{
  "name": "@mobayilo/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable building blocks shared across mobayilo projects: themes, magic-link auth, and Telegram connect.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist",
    "deploy:site": "pnpm -r build && pnpm --filter @mobayilo/design-system-site deploy"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
