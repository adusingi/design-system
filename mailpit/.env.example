# @mobayilo/mailpit — environment variables
#
# Mailpit captures all outbound SMTP locally and shows it in a web UI. Run it
# with the bundled docker-compose.mailpit.yml (SMTP on :1025, UI/API on :8025).
# All values below have sensible defaults; you usually need none of them for a
# plain local setup.

# ── Delivery toggle (mailpitEnabledFromEnv) ──────────────────────────────────
# Whether mail goes to Mailpit (true) or your real provider (false). DEFAULTS
# TO true when unset, so nothing escapes to a real provider in an unconfigured
# environment. Set to false in production to send for real.
MAILPIT_ENABLED=true

# ── SMTP transport (createMailpitMailer / mailpitMailerConfigFromEnv) ─────────
# Host/port Mailpit listens on. Use the compose service name (e.g. "mailpit")
# when your app runs inside the same docker network; "localhost" otherwise.
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
# Mailpit accepts anonymous SMTP by default — leave these blank unless you
# enabled auth via MP_SMTP_AUTH on the Mailpit container.
MAILPIT_SMTP_USER=
MAILPIT_SMTP_PASS=
# "true" to connect over TLS. Local Mailpit is plain SMTP, so keep it false.
MAILPIT_SMTP_SECURE=false

# Sender. MAILPIT_FROM_ADDRESS wins; otherwise the conventional EMAIL_FROM is
# reused, so apps already setting EMAIL_FROM need nothing here.
MAILPIT_FROM_ADDRESS=no-reply@localhost
MAILPIT_FROM_NAME=Mobayilo
MAILPIT_REPLY_TO=
# EMAIL_FROM=MyApp <no-reply@localhost>

# ── REST-API inbox client (createMailpitClient / mailpitClientConfigFromEnv) ──
# Base URL of the Mailpit web/API server. Use the compose service name in-network.
MAILPIT_API_URL=http://localhost:8025
# Only if you protected the Mailpit UI with MP_UI_AUTH (user:pass) — usually blank.
MAILPIT_UI_USER=
MAILPIT_UI_PASS=
